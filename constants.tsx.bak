// HELPER: Create 20 items per category
const generate20Items = (domain: DCMQuestion['domain'], category: string, baseTexts: string[]): DCMQuestion[] => {
  const result: DCMQuestion[] = [];
  for (let i = 1; i <= 20; i++) {
    result.push({
      id: `q-${domain[0].toLowerCase()}-${category.replace(/\s+/g, '-').toLowerCase()}-${i}`,
      domain,
      category,
      text: baseTexts[i - 1] || `${category} - Masalah butir ke-${i}`
    });
  }
  return result;
};

